# Base URL of the Express backend API (no trailing slash).
# Example: https://api.foodforlifedrc.org
NEXT_PUBLIC_API_BASE_URL=

# Toggle between mock data (true) and the real backend (false).
# Keep "true" until the Express backend is wired up.
NEXT_PUBLIC_USE_MOCKS=true

# Public site URL (used for metadata / canonical links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
