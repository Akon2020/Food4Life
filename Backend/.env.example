# Copier vers .env.development.local (dev) ou .env.production.local (prod).
# Ne jamais committer les fichiers .local (ils contiennent des secrets).

NODE_ENV="development"
PORT=5000
URL_ORIGIN="http://localhost:5000"

# Base de données MySQL
DB_HOST="localhost"
DB_USER="root"
DB_PASS=""
DB_NAME="foodforlife"
# "true" => DROP & RECREATE de tout le schéma au démarrage / au seed (DEV UNIQUEMENT).
# Garder "false" en temps normal pour ne pas vider la base.
DB_SYNC_FORCE="false"

# JWT
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"

# Email (SMTP perso — D9). Soigner SPF/DKIM/DMARC en prod.
EMAIL_HOST=""
EMAIL="no-reply@foodforlifedrc.org"
EMAIL_PASSWORD=""
CONTACT_EMAIL=""

# URLs
HOST_URL="http://localhost:5000"
FRONT_URL="http://localhost:3000"

# Compte admin initial (seedé si aucun utilisateur)
DEFAULT_PASSWD="Food4Life@2026"
ADMIN_EMAIL="admin@foodforlifedrc.org"
ADMIN_NAME="Isaac Akonkwa"
